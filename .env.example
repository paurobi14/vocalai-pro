# ============================================================
#  VocalAI Pro — Environment Configuration
#  Copia este archivo como .env y rellena los valores reales
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=https://tudominio.com          # URL pública para webhooks de Twilio

# ── Database (PostgreSQL) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vocalai_pro
DB_USER=vocalai
DB_PASSWORD=supersecret
DB_POOL_MAX=20

# ── Redis (cola de llamadas) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+34xxxxxxxxx        # Número desde el que llama la IA
TWILIO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx  # Para validar requests de Twilio

# ── ElevenLabs (Clonación de voz) ───────────────────────────
ELEVENLABS_API_KEY=el_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=                   # Se rellena tras clonar la voz del empresario

# ── Claude / Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Google Calendar ──────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://tudominio.com/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=                  # Se obtiene en el flujo OAuth inicial
GOOGLE_CALENDAR_ID=primary             # ID del calendario donde crear las citas

# ── Seguridad ────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio
ENCRYPTION_KEY=32caracteres_para_aes256_exacto!!

# ── Notificaciones ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=app_password_aqui
EMAIL_FROM="VocalAI Pro <noreply@tudominio.com>"

# ── Configuración de llamadas ────────────────────────────────
CALL_MAX_DURATION=300                  # Duración máxima en segundos (5 min)
CALL_RETRY_MAX=2                       # Reintentos si no contesta
CALL_RETRY_DELAY_HOURS=2              # Horas entre reintentos
CALL_HOURS_START=09:00                 # Inicio jornada de llamadas
CALL_HOURS_END=18:30                   # Fin jornada de llamadas
CALL_TIMEZONE=Europe/Madrid

# ── Idiomas soportados ───────────────────────────────────────
SUPPORTED_LANGUAGES=es,ca,en
DEFAULT_LANGUAGE=es

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000            # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100
